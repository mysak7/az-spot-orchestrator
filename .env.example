# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/az_spot_orchestrator

# Azure service principal
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret

# Azure resource defaults
AZURE_RESOURCE_GROUP=az-spot-orchestrator-rg
# SSH public key content (required for VM creation)
AZURE_SSH_PUBLIC_KEY=ssh-rsa AAAA...

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=vm-provisioning

# Control plane (used in cloud-init to callback)
CONTROL_PLANE_URL=http://YOUR_PUBLIC_IP:8000

# Optional VM size override (default is GPU-capable SKU)
DEFAULT_VM_SIZE=Standard_NC4as_T4_v3
