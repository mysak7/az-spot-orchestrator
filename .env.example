# All values below are non-secret configuration.
# In production these are written by the CD pipeline from GitHub Actions Variables,
# which are auto-populated by `terraform apply` — nothing to set manually.
#
# Auth uses the control-plane VM's managed identity (DefaultAzureCredential).
# No keys, no client secrets, no tokens stored anywhere.

COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/

AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=az-spot-orchestrator-rg
AZURE_SSH_PUBLIC_KEY=ssh-rsa AAAA...

AZURE_STORAGE_ACCOUNT_NAME=azspotmodelcache
AZURE_STORAGE_CONTAINER_NAME=model-cache

CONTROL_PLANE_URL=http://YOUR_PUBLIC_IP

# Temporal (overridden to temporal:7233 inside docker-compose)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=vm-provisioning
