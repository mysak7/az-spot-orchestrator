# Azure Cosmos DB (populated from `terraform output` after apply)
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-primary-key==

# Azure service principal
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret

# Azure resource defaults
AZURE_RESOURCE_GROUP=az-spot-orchestrator-rg
# SSH public key content (required for Spot VM creation)
AZURE_SSH_PUBLIC_KEY=ssh-rsa AAAA...

# Temporal dev server (SQLite — no DB config needed)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=vm-provisioning

# Control plane public URL (set after Terraform apply; embedded into cloud-init)
CONTROL_PLANE_URL=http://YOUR_PUBLIC_IP:8000

# Optional VM size override
DEFAULT_VM_SIZE=Standard_NC4as_T4_v3
